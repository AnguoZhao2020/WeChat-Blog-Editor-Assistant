{
  "manifest_version": 3,
  "name": "公众号全屏HTML编辑器",
  "version": "4.0",
  "description": "全屏HTML源码编辑，语法高亮，SVG优化，预设正则替换规则。",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["*://mp.weixin.qq.com/cgi-bin/appmsg*"],
  "icons":{
      "16": "icons/editor_off.png",
      "48": "icons/html48.png",
      "128": "icons/html128.png"
    },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "切换全屏HTML编辑",
    "default_icon": {
      "16": "icons/editor_off.png",
      "48": "icons/html48.png",
      "128": "icons/html128.png"
    }
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://mp.weixin.qq.com/cgi-bin/appmsg*"],
      "js": [
        "injection.js"
      ],
      "run_at": "document_end",
      "type":"module"
    }
  ]
}